export MCFLY_FUZZY=2
export MCFLY_RESULTS=50
export MCFLY_DELETE_WITHOUT_CONFIRM=true
export MCFLY_INTERFACE_VIEW=BOTTOM
export MCFLY_DISABLE_MENU=FALSE
export MCFLY_RESULTS_SORT=LAST_RUN
export MCFLY_PROMPT="❯"
