# General Settings in this file
# Compositor settings in env-hyprland for hypr and aquamarin
# Source Laptop od desktop specific vars depending on hostname
case "$(hostname)" in
  Laptop)
    [ -r "$HOME/.config/uwsm/env-laptop" ] && . "$HOME/.config/uwsm/env-laptop"
    ;;
  Tower)
    [ -r "$HOME/.config/uwsm/env-desktop" ] && . "$HOME/.config/uwsm/env-desktop"
    ;;
esac


# UWSM
export UWSM_WAIT_VARNAMES=${UWSM_WAIT_VARNAMES}\ FINALIZED
export APP2UNIT_SLICES=a=app-graphical.slice\ b=background-graphical.slice\ s=session-graphical.slice
export DE=generic
export WINDOW_MANAGER=Hyprland
export BROWSER=firefox
export LANG=en_US.UTF-8

# Wayland
#export WAYLAND_DISPLAY= # This gets set automatically by session
#export SDL_VIDEODRIVER=wayland,x11,* # This likes to break my windows
export CLUTTER_BACKEND=wayland
export MOZ_ENABLE_WAYLAND=1

# Shell
export EDITOR=vim
export VISUAL=vim
export PAGER=vim
export TERMINAL=xterm-ghostty
export TERM=xterm-ghostty
export TERMCMD=foot
export ZSH_THEME="robbyrussell"
export ZSH=$HOME/.oh-my-zsh
export MANPATH=/usr/local/man:$MANPATH
export ARCHFLAGS=-arch\ $(uname -m)
export LESS=R\ -N\ --mouse\ --use-color\ -Dd+r\ -Du+b
export KITTY_ENABLE_WAYLAND=1
export PROGRESS_ARGS="--monitor-continuously"

# Config Paths
export RIPGREP_CONFIG_PATH=~/.config/.ripgreprc
export PNPM_HOME="/home/TatenK/.local/share/pnpm"
export PARU_CONF="$HOME/.config/paru.conf"
export FZF_DEFAULT_OPTS_FILE=$HOME/.config/fzf.conf
export MAGICK_CONFIGURE_PATH=$HOME/.config/

# Mcfly
export FLY_HISTORY=$HOME/Documents/logging/mcfly.history
