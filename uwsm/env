# everything except HYPR* and AQ* envirorment var, those go into env-hyprland
# UWSM
export UWSM_WAIT_VARNAMES=${UWSM_WAIT_VARNAMES}\ FINALIZED
export APP2UNIT_SLICES=a=app-graphical.slice\ b=background-graphical.slice\ s=session-graphical.slice

# Wayland
#export WAYLAND_DISPLAY=
#export SDL_VIDEODRIVER=wayland,x11,* # This likes to break my windows
export CLUTTER_BACKEND=wayland
export MOZ_ENABLE_WAYLAND=1

# Shell
export EDITOR=nvim
export VISUAL=nvim
export TERM=xterm-ghostty
export TERMCMD=ghostty
export ZSH=$HOME/.oh-my-zsh
export MANPATH=/usr/local/man:$MANPATH
export ARCHFLAGS=-arch\ $(uname -m)
export LESS=R\ -N\ --mouse\ --use-color\ -Dd+r\ -Du+b
#export KITTY_ENABLE_WAYLAND=1

# Steam / VR
export VK_DRIVER_FILES=/usr/share/vulkan/icd.d/nvidia_icd.json
export XR_RUNTIME_JSON=/usr/share/openxr/1/openxr_monado.json
export LD_LIBRARY_PATH=$HOME/.steam/steamapps/common/SteamVR:$HOME/.steam/steamapps/common/SteamVR/bin/linux64:$HOME/.steam/steamapps/common/SteamVR/bin/linux64/qt/lib:.local/share/Steam/steamapps/common/SteamVR/bin/linux64/qt/lib/libQt5Multimedia.so.5:$LD_LIBRARY_PATH
export XRT_COMPOSITOR_FORCE_WAYLAND_DIRECT=1
export VR_OVERRIDE=/opt/xrizer
export STEAMVR_LH_ENABLE=true
export PRESSURE_VESSEL_FILESYSTEMS_RW=$XDG_RUNTIME_DIR/monado.pid
export OXR_PARALLEL_VIEWS=1
export XRT_COMPOSITOR_FORCE_NVIDIA_DISPLAY=NVIDIA
export VIT_SYSTEM_LIBRARY_PATH=/usr/lib/libbasalt.so

# GTK
export GDK_BACKEND=wayland,x11
export GTK_THEME=dark
export GTK_USE_PORTAL=1
export GDK_SCALE=1 #1 was set before might revert

# XDG
export XDG_CURRENT_DESKTOP=Hyprland
export XDG_SESSION_TYPE=wayland
export XDG_SESSION_DESKTOP=Hyprland

# Nvidia
export LIBVA_DRIVER_NAME=nvidia
export NVD_BACKEND=direct
export __NV_PRIME_RENDER_OFFLOAD=1
export __GLX_VENDOR_LIBRARY_NAME=nvidia
export __VK_LAYER_NV_optimus=NVIDIA_only
export __GL_GSYNC_ALLOWED=0
export __GL_VRR_ALLOWED=0
export GBM_BACKEND=nvidia-drm
export __NV_PRIME_RENDER_OFFLOAD_PROVIDER=PCI:13:0:0

# QT
export QT_STYLE_OVERRIDE=kvantum-dark
export QT_WAYLAND_DISABLE_WINDOWDECORATION=0
export QT_AUTO_SCREEN_SCALE_FACTOR=1
#export QT_QPA_PLATFORM=wayland,x11 ##This setting breaks qt plugin, for now just leave unset
export QT_QPA_PLATFORMTHEME=hyprqt6engine # qt6ct
export QT_PLUGIN_PATH=~/tools/hyprqt6engine/hyprqtplugin #/usr/lib/qt6/plugins
export QT_DEBUG_PLUGINS=1
export ELECTRON_OZONE_PLATFORM_HINT=auto
