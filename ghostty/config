vt-kam-allowed = false
grapheme-width-method = unicode
alpha-blending = linear-corrected
freetype-load-flags = hinting,force-autohint,no-monochrome,autohint

cursor-style = block
cursor-click-to-move = true
cursor-style-blink = false
cursor-text = cell-background
scroll-to-bottom = keystroke,no-output
mouse-hide-while-typing = true
mouse-shift-capture = never
mouse-scroll-multiplier = precision:1,discrete:1
background-opacity = 0
background-blur = 20
background-opacity-cells = false
unfocused-split-opacity = 1
scrollback-limit = 10000000
link-url = true
link-previews = true
maximize = false
fullscreen = false
title =
working-directory = home

quit-after-last-window-closed = false
keybind = clear
keybind = ctrl++=increase_font_size:1
keybind = ctrl+-=decrease_font_size:1
keybind = ctrl+v=paste_from_clipboard

window-save-state = never
window-inherit-font-size = true
window-inherit-working-directory = true
window-theme = dark
window-new-tab-position = current
window-show-tab-bar = never
window-subtitle = working-directory
resize-overlay = after-first
resize-overlay-position = center
resize-overlay-duration = 500ms
focus-follows-mouse = true
clipboard-read = allow
clipboard-write = allow
clipboard-trim-trailing-spaces = true
clipboard-paste-protection = true
clipboard-paste-bracketed-safe = true
title-report = false
image-storage-limit = 4294967295
copy-on-select = true
right-click-action = context-menu
click-repeat-interval = 0
confirm-close-surface = false
initial-window = true
shell-integration = zsh
shell-integration-features = no-cursor,no-sudo,title,no-ssh-env,no-ssh-terminfo


osc-color-report-format = 16-bit
custom-shader-animation = false
bell-features = system,no-audio,attention,no-title,border
bell-audio-volume = 0
app-notifications = clipboard-copy,config-reload

linux-cgroup = always
linux-cgroup-memory-limit = 
linux-cgroup-processes-limit = 
linux-cgroup-hard-fail = false
gtk-opengl-debug = false
gtk-single-instance = false
gtk-titlebar-style = tabs
gtk-titlebar = false
gtk-titlebar-hide-when-maximized = true
gtk-toolbar-style = flat
gtk-wide-tabs = false
gtk-tabs-location = hidden
gtk-custom-css = 
desktop-notifications = true
faint-opacity = 0.5
term = xterm-ghostty
enquiry-response = 
async-backend = auto
auto-update = off

initial-command=/home/TatenK/.config/ghostty/starttmux.sh
click-repeat-interval = 500
wait-after-command = false
abnormal-command-exit-runtime = 250

window-padding-color = extend-always
window-padding-balance = true
window-padding-x=3,3
window-padding-y=3,3
window-decoration = auto
window-theme = auto
