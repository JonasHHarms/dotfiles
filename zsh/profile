#  My Zshrc
#   Sets shell enviroment for non login shells 


# exports
export ZSH="$HOME/.oh-my-zsh"
export MANPATH="/usr/local/man:$MANPATH"
export ARCHFLAGS="-arch $(uname -m)"

# zsh-settings
plugins=(git sudo fzf git-prompt zoxide zsh-autosuggestions)
CASE_SENSITIVE="true"
ENABLE_CORRECTION="false"
COMPLETION_WAITING_DOTS="true"
DISABLE_UNTRACKED_FILES_DIRTY="false"
HIST_STAMPS="dd.mm.yyyy"
HISTSIZE=100000
SAVEHIST=100000
HISTFILE="$HOME/.cache/zsh_history"
KEYBOARD_HACK=#

# Prompt
setopt PROMPT_SUBST
TMOUT=30
TRAPALRM() {
  zle reset-prompt
}
export PS1=" %F{blue}%D{%H:%M}  󰣇  %f%~/ $ "

# opts
unsetopt xtrace # prints the comands beeing executed spams stoud
unsetopt verbose # extra verbose log printing,
setopt notify # tells status changes of background jobs
setopt auto_list
setopt auto_param_keys
setopt auto_param_slash 
setopt auto_continue
setopt auto_resume
unsetopt correct
setopt extended_glob
setopt pushd_ignore_dups
setopt autocd
setopt cdable_vars
setopt print_exit_value
setopt rm_star_wait
setopt sun_keyboard_hack
setopt interactive_comments
setopt auto_menu 
setopt menu_complete
setopt long_list_jobs
setopt pipe_fail
setopt globdots
unsetopt prompt_sp
setopt hist_ignore_all_dups
setopt hist_ignore_space
setopt hist_lex_words
setopt hist_reduce_blanks
setopt hist_save_no_dups
setopt hist_reduce_blanks
setopt append_history
setopt inc_append_history
setopt share_history
# zstyle ':completion:' menu select

eval "$(zoxide init zsh)"
#source /usr/share/doc/mcfly/mcfly.zsh
source $HOME/.config/zsh/fzfinit.sh
source $HOME/.config/zsh/mcflyinit.sh

# Functions
y() {
	local tmp="$(mktemp -t "yazi-cwd.XXXXXX")" cwd
	yazi "$@" --cwd-file="$tmp"
	if cwd="$(<"$tmp")" && [[ -n "$cwd" && "$cwd" != "$PWD" ]]; then
		builtin cd -- "$cwd"
	fi
	rm -f -- "$tmp"
}


