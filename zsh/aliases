# print all chars
alias ali="bat ~/.config/zsh/aliases"

# remaps
alias cat="bat"
alias grep="rg"
alias cd='z'
alias fuck='ups'
alias vi="nvim -n"
alias ls='eza --color=always --icons=always --all --git --mounts --sort=filename --no-quotes --tree --classify=always --grid --color-scale=all --color-scale-mode=gradient --hyperlink --group-directories-first --long --header --binary --changed --no-permissions --no-user'
alias whoami="whoami && ~/.config/eww/scripts/getloc.sh"
alias dust="dust --force-colors --depth 1 --skip-total --number-of-lines=500 --reverse --invert-filter='git'"
alias history="mcfly --history_format=zsh search"
alias pastel="pastel --color-picker hyprpicker"
alias ddgr="ddgr --num=25 --reg=us-en --unsafe --noua --reverse --colors=oCdgxy"
alias newsboat="newsboat --config-file=$HOME/.config/newsboat/config --url-file=$HOME/.config/newsboat/urls"

# Shortcuts
alias rstudio="/usr/lib/rstudio/rstudio & disown"
alias eww="/etc/eww/target/release/eww"
alias ohmyzsh="mate ~/.oh-my-zsh"
alias ff="firefox & disown"
alias weather="curl -s 'http://wttr.in/FRA'"
 # troubleshooters
alias networkfix="rmmod mt7925e; modprobe mt7925e"
