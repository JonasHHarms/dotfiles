alias cat="bat"
alias ali="cat ~/.config/zsh/aliases"
alias rstudio="/usr/lib/rstudio/rstudio & disown"
alias clr="clear;fastfetch -l none"
alias eww="/etc/eww/target/release/eww"
alias cd='z'
alias ohmyzsh="mate ~/.oh-my-zsh"
alias reboot="systemctl reboot"
alias poweroff="systemctl poweroff"
alias vi="nvim -n"
alias lls="ls -l --all --human-readable | column -C"
alias ff="firefox & disown"
alias fans="asusctl profile --profile-set Quiet"
alias whoami="whoami && ~/.config/eww/scripts/getloc.sh"
alias networkfix="rmmod mt7925e; modprobe mt7925e"
